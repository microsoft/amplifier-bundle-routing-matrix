// triage-review.dot
//
// Pipeline: Automated GitHub Issue Triage — Flat Supervisor-Free Pattern
//
// ARCHITECTURE: Each node is a top-level pipeline node with its own spawned
// child session. No shape=house manager. This gives full visibility:
//   [PIPELINE] ▶ investigate [box]
//   [PIPELINE] ▶ quality_eval [diamond]
//   [PIPELINE] -> edge: quality_eval --[outcome!=success]--> investigate  (retry)
//   [PIPELINE] -> edge: quality_eval --[outcome=success]--> comment_draft (pass)
//
// Threads:
//   triage-thread  — investigate + comment_draft (context accumulates across cycles)
//   quality-thread — quality_eval only (fresh adversarial context each cycle)
//
// Cycle limit: quality_eval.timeout=2m + investigate.timeout=5m naturally
// bounds each cycle. goal_gate=true on quality_eval tracks overall success.

digraph triage_review {

    // ── Graph-level attributes ───────────────────────────────────────────────

    label             = "Issue Triage Review"
    labelloc          = t
    rankdir           = TB
    compound          = true
    fontname          = "Helvetica"
    nodesep           = 0.6
    ranksep           = 0.9

    // Attractor pipeline configuration
    goal              = "Triage the GitHub issue described in the conversation context"
    default_fidelity  = "full"
    default_thread_id = "triage-thread"

    // ── Default node and edge styles ─────────────────────────────────────────
    node [fontname="Helvetica", fontsize=11, style="filled"]
    edge [fontname="Helvetica", fontsize=10, color="#555555"]

    // ═══════════════════════════════════════════════════════════════════════
    // PIPELINE NODES — all top-level, each gets its own child session
    // ═══════════════════════════════════════════════════════════════════════

    // Entry point
    start [
        label     = "Start",
        shape     = Mdiamond,
        fillcolor = "#C8E6C9"
    ]

    // Investigator — independent root-cause analysis against actual code.
    // Runs on triage-thread so it sees steering from prior quality_eval cycles.
    // MUST NOT post any GitHub comment — findings go to quality_eval only.
    investigate [
        label     = "Investigate",
        shape     = box,
        fillcolor = "#E8F0FE",
        timeout   = "5m",
        prompt    = "IMPORTANT: Do NOT post any comments to GitHub via any mechanism (github_post_comment, gh CLI, bash, curl, or any other tool). Output your findings as text only — quality_eval will evaluate them. Investigate the GitHub issue in $goal. Do not anchor your analysis on any prior comments in the issue thread. Form your own hypotheses and test them independently against the actual code. All Amplifier ecosystem repos are under the 'microsoft' GitHub organization — use github_checkout_repo with owner='microsoft' (e.g. owner='microsoft', repo='amplifier-core'). Report: proposed root cause with file:line, affected ecosystem layer/repo, and whether the issue would affect other providers/modules."
    ]

    // Adversarial quality gate — evaluates investigate findings.
    // Runs on quality-thread (fresh context) for genuine independence.
    // Calls report_outcome(outcome='success'|'fail', reason='...').
    quality_eval [
        label            = "Quality Gate",
        shape            = diamond,
        fillcolor        = "#FFF9C4",
        goal_gate        = true,
        timeout          = "2m",
        reasoning_effort = high,
        prompt           = "You are an adversarial reviewer. Your job is to disagree with the investigator and find what they got wrong. You have no ability to generate your own findings — only to evaluate whether the investigator's findings hold up. Check ALL of the following before calling report_outcome: (1) PROXY CHECK: Did the investigator anchor conclusions on prior issue comments, the reporter's framing, or agent summaries? If the conclusion just restates what was already in the issue thread without independent code verification, that is a proxy conclusion — FAIL. (2) SPECIFICITY: Is the root cause pinned to a specific file:line? 'Probably in this function' or 'likely related to' is not a root cause — FAIL. (3) LAYER CHECK — Ecosystem hierarchy (innermost to outermost): amplifier-core → amplifier-module-* → amplifier-foundation → amplifier-bundle-* → amplifier-app-cli. If the proposed fix is in a single provider module but the root cause would affect all providers, the fix belongs in amplifier-core — FAIL. Ask: who does this NOT protect? (4) DIMENSIONALITY: Did the investigator compare a working vs broken scenario to find the divergence point? Did they check sibling modules for the same issue? Or did they only investigate the single broken path? Single-dimensional investigation = FAIL. (5) RECOMMENDATION: Does the output have a concrete recommendation, or just a list of options for the user to decide? Analysis without a recommendation is incomplete — FAIL. (6) STRUCTURE: Does the output lead with the conclusion in plain English, or does it bury the finding after pages of investigation detail? If you cannot state the root cause in 2-3 sentences without jargon, it is not ready — FAIL. Call report_outcome(outcome='success') only if ALL six checks pass. Call report_outcome(outcome='fail', reason='[specific criterion that failed and why]') if any check fails."
    ]

    // Drafter + poster — writes and posts the final GitHub comment.
    // Uses commenter profile (has github_post_comment).
    // Runs on triage-thread so it sees the full investigation history.
    comment_draft [
        label        = "Post Analysis",
        shape        = box,
        fillcolor    = "#E8F0FE",
        llm_provider = "anthropic-commenter",
        prompt       = "The GitHub issue is described in $goal — extract the owner, repo name, and issue number from it. Write a final triage comment and post it to that issue using github_post_comment. Structure it inductively: lead with a 2-3 sentence plain-English summary of the root cause and recommended fix (no jargon), then provide supporting evidence. Be direct — give a recommendation, not a menu of options. Only report what was independently verified through code, not what prior comments suggested."
    ]

    // Pipeline exit
    done [
        label     = "Done",
        shape     = Msquare,
        fillcolor = "#FFCDD2"
    ]

    // ═══════════════════════════════════════════════════════════════════════
    // EDGES
    // ═══════════════════════════════════════════════════════════════════════

    start -> investigate

    // Investigator delivers findings to quality gate.
    // quality-thread = fresh adversarial context (compact summary only).
    investigate -> quality_eval [
        thread_id = "quality-thread",
        fidelity  = "compact"
    ]

    // SUCCESS: quality approved — move to drafting and posting the comment.
    quality_eval -> comment_draft [
        label     = "outcome=success",
        condition = "outcome=success",
        color     = "#43A047",
        fontcolor = "#43A047"
    ]

    // FAIL: quality rejected — investigator retries with critique in context.
    // triage-thread: investigator sees the quality_eval failure reason.
    quality_eval -> investigate [
        label     = "outcome!=success",
        condition = "outcome!=success",
        thread_id = "triage-thread",
        style     = dashed,
        color     = "#E57373",
        fontcolor = "#E57373"
    ]

    comment_draft -> done

}
