// triage-review.dot
//
// Pipeline: Automated GitHub Issue Triage — Flat Supervisor-Free Pattern
//
// ARCHITECTURE (microsoft-amplifier / amplifier-support pattern):
//   - Flat: every node is a top-level pipeline node, no shape=house supervisor.
//   - Adversarial quality gate: quality_eval independently verifies the
//     investigation before any comment is posted.
//   - NO HITL: the pipeline runs end-to-end with no human approval gates.
//
//   start -> investigate -> quality_eval -> comment_draft -> done
//
// The quality gate retries the investigator via retry_target="investigate"
// when any of the six criteria fail (bounded by max_cycles).

digraph triage_review {

    // ── Graph-level attributes ──────────────────────────────────────────────
    label             = "Issue Triage Review"
    description       = "Investigate an issue, verify claims against actual code, post triage findings"
    labelloc          = t
    rankdir           = TB
    compound          = true

    // Attractor pipeline configuration
    goal              = "$goal"
    default_fidelity  = "full"
    default_thread_id = "triage-thread"

    // Per-node model role assignment
    model_stylesheet  = "investigate: model_role=reasoning; quality_eval: model_role=critique; comment_draft: model_role=general"

    // ── Default node and edge styles ────────────────────────────────────────
    node [fontname="Helvetica", fontsize=11, style="filled"]
    edge [fontname="Helvetica", fontsize=10, color="#555555"]

    // ════════════════════════════════════════════════════════════════════════
    // PIPELINE NODES — all top-level, each gets its own child session
    // ════════════════════════════════════════════════════════════════════════

    // Entry point
    start [
        label     = "Start",
        shape     = Mdiamond,
        fillcolor = "#C8E6C9"
    ]

    // Investigator — senior-engineer root-cause analysis against actual code.
    investigate [
        label      = "Investigate",
        shape      = box,
        fillcolor  = "#E8F0FE",
        max_cycles = 3,
        prompt     = "You are a senior engineer investigating the GitHub issue described in $goal.\n\nQUALITY GATE FEEDBACK FROM PREVIOUS CYCLE (empty on first run):\ncontext.quality_feedback\nIf the above is non-empty, address every listed failure explicitly this cycle.\n\nRULES:\n- NEVER trust the reporter's framing. The reporter can be wrong.\n- Verify every claim against the actual source code before repeating it.\n- Check that every file/symbol the reporter mentions actually exists.\n- Identify the root cause (specific file:line), the affected files, and the blast radius (who else is impacted).\n- If the issue is vague, state exactly what information is missing.\n\nSTEP 1 - LOAD THE RUBRIC:\n  read_file .github/amplifier/triage-context.md\nThis file contains the full investigation rubric and the six quality criteria. Follow it.\n\nSTEP 2 - INVESTIGATE the issue from $goal, verifying claims against real code.\n\nSTEP 3 - WRITE FINDINGS to docs/triage/investigation.md with EXACTLY these sections:\n  ## SUMMARY        - 2-3 sentence plain-English conclusion (written FIRST)\n  ## ROOT CAUSE     - specific file:line, no hedging\n  ## AFFECTED FILES - list of files/modules impacted (blast radius)\n  ## SEVERITY       - low | medium | high | critical, with one-line justification\n  ## RECOMMENDATION - one of: simple-fix | needs-dotpowers | needs-investigation | wontfix\n  ## SUGGESTED FIX  - concrete next step (or what is missing, if needs-investigation)\n\nSTEP 4 - COMMIT the findings:\n  git add docs/triage/investigation.md && git commit -m \"docs(triage): record investigation findings\"\n\nSTEP 5 - FINAL OUTPUT (CRITICAL):\nYour entire response must be ONLY this JSON object — no prose, no markdown:\n{\"status\": \"success\", \"context_updates\": {\"investigation_summary\": \"<the full SUMMARY + ROOT CAUSE + AFFECTED FILES + SEVERITY block as one string, using \\n for newlines>\", \"recommendation\": \"<simple-fix|needs-dotpowers|needs-investigation|wontfix>\"}}"
    ]

    // Adversarial quality gate — verifies the investigation against all six
    // criteria before any comment is posted. Retries investigate on failure.
    quality_eval [
        label        = "Quality Gate",
        shape        = box,
        fillcolor    = "#FFF9C4",
        goal_gate    = true,
        retry_target = "investigate",
        max_cycles   = 2,
        prompt       = "YOUR RESPONSE MUST START WITH { — no preamble, no text before the opening brace. The pipeline JSON-parses the first character.\n\nYou are an adversarial quality reviewer. Do all reasoning in thinking/tool calls, then output ONLY the JSON object.\n\nINVESTIGATION UNDER REVIEW:\ncontext.investigation_summary\n(The full report is in docs/triage/investigation.md — read it if needed.)\n\nCheck the investigation against ALL SIX criteria:\n(1) PROXY CHECK   - Did the investigator verify from code independently, or just restate the reporter's description? FAIL if no independent verification.\n(2) SPECIFICITY   - Is the root cause a specific file:line? Vague = FAIL.\n(3) LAYER CHECK   - Is the fix at the correct ecosystem layer (core -> module-* -> foundation -> bundle-* -> app-cli)? A fix that misses siblings = FAIL.\n(4) DIMENSIONALITY - Were sibling modules explicitly checked? Only one checked = FAIL.\n(5) RECOMMENDATION valid - Is RECOMMENDATION exactly one of simple-fix|needs-dotpowers|needs-investigation|wontfix, and is it the right call? A menu of options = FAIL.\n(6) STRUCTURE     - Are ALL required sections present (SUMMARY, ROOT CAUSE, AFFECTED FILES, SEVERITY, RECOMMENDATION, SUGGESTED FIX)? Missing/truncated = FAIL.\n\nYour ENTIRE response must be ONLY one of these two JSON objects:\n\nOn FAIL (any criterion):\n{\"status\": \"fail\", \"context_updates\": {\"quality_feedback\": \"QUALITY GATE FAILED. Fix these issues:\\n- [criterion]: [what was wrong and exactly what to do]\"}}\n\nOn SUCCESS (all six pass):\n{\"status\": \"success\", \"context_updates\": {\"quality_verdict\": \"PASS: all six criteria satisfied\"}}\n\nNo prose. No markdown. Just the JSON."
    ]

    // Drafter + poster — writes and posts the final GitHub comment(s).
    comment_draft [
        label     = "Post Triage",
        shape     = box,
        fillcolor = "#E8F0FE",
        prompt    = "Read the verified findings from docs/triage/investigation.md. The GitHub issue is described in $goal — extract the owner, repo, and issue number from it.\n\nSTEP 1 - POST THE TRIAGE COMMENT using the github_post_comment tool. The comment must include:\n  - Summary (2-3 sentence plain-English conclusion)\n  - Root cause (file:line)\n  - Affected files (blast radius)\n  - Severity\n  - Recommendation\nBase everything strictly on investigation.md — no speculation.\n\nSTEP 2 - ACT ON THE RECOMMENDATION (value is in context.recommendation):\n  - 'simple-fix': post a SECOND comment via github_post_comment containing exactly:\n      /resolve new_instance(resolver=\"dot-graph\", pipeline=\"custom\", path=\"./.amplifier-resolve/simple-fix.dot\")\n    then apply the label 'ready-to-implement'.\n  - 'needs-dotpowers': post a SECOND comment via github_post_comment containing exactly:\n      /resolve new_instance(resolver=\"dot-graph\", pipeline=\"dotpowers\")\n    then apply the label 'ready-to-implement'.\n  - 'needs-investigation': apply the label 'needs-investigation'. Do NOT post a /resolve comment.\n  - 'wontfix': apply the label 'wontfix'. Do NOT post a /resolve comment.\n\nSTEP 3 - FINAL OUTPUT (CRITICAL):\nYour entire response must be ONLY this JSON object:\n{\"status\": \"success\", \"context_updates\": {\"triage_posted\": true}}"
    ]

    // Pipeline exit
    done [
        label     = "Done",
        shape     = Msquare,
        fillcolor = "#FFCDD2"
    ]

    // ════════════════════════════════════════════════════════════════════════
    // EDGES — flat chain; quality_eval retries investigate via retry_target
    // ════════════════════════════════════════════════════════════════════════

    start         -> investigate
    investigate   -> quality_eval
    quality_eval  -> comment_draft
    comment_draft -> done

}
