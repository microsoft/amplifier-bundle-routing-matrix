// implement.dot
//
// Pipeline: Code Fix Demo
//
// Simple flow for demonstrating issue -> fix -> results:
//   1. Planner reads issue + triage findings, writes fix plan
//   2. Implement the fix (LLM handles TDD, tests, commits internally)
//   3. Comment draft posts results back to the GitHub issue via bridge.*

digraph implement_fix {

    // — Graph-level attributes ————————————————————————————————————

    label             = "Implement Fix"
    description       = "Plan and implement a code fix or feature, then report results"
    labelloc          = t
    rankdir           = TB
    compound          = true

    // Attractor pipeline configuration
    goal              = "$goal"
    default_fidelity  = "full"
    default_thread_id = "implement-fix-thread"

    // — Model stylesheet ——————————————————————————————————————————
    model_stylesheet  = "planner: model_role=reasoning; implement_fix: model_role=coding; comment_draft: model_role=general"

    // — Default node and edge styles —————————————————————————————
    node [fontname="Helvetica", fontsize=11, style="filled"]
    edge [fontname="Helvetica", fontsize=10, color="#555555"]

    // ═══════════════════════════════════════════════════════════════
    // PIPELINE NODES
    // ═══════════════════════════════════════════════════════════════

    // Entry point
    start [
        label     = "Start",
        shape     = Mdiamond,
        fillcolor = "#C8E6C9"
    ]

    // Planner — reads issue + triage from $goal, writes concise fix plan
    planner [
        label      = "Planner",
        shape      = box,
        fillcolor  = "#E8F0FE",
        max_cycles = 2,
        prompt     = "You are a fix planner. Read the issue and any triage analysis from $goal.\n\nWrite a concise fix plan to docs/fix-plan.md with these sections:\n- ROOT CAUSE: What is broken and why\n- FILES TO CHANGE: Exact files and what changes in each\n- TEST STRATEGY: What tests to write/modify to verify the fix\n- VERIFICATION: How to confirm the fix works end-to-end\n\nThen git add and git commit the plan.\n\nOutput:\n{\"status\": \"success\", \"context_updates\": {\"fix_plan\": \"docs/fix-plan.md written\"}}"
    ]

    // Implement fix — the LLM handles everything: write tests, write code,
    // run tests, fix failures, git add, git commit. Same pattern as
    // dotpowers' ImplementTask.
    implement_fix [
        label      = "Implement Fix",
        shape      = box,
        fillcolor  = "#E8F0FE",
        max_cycles = 3,
        goal_gate  = true,
        fidelity   = "full",
        prompt     = "You are implementing a code fix.\n\nRead the fix plan from docs/fix-plan.md.\n\nProcess:\n1. Write a test that reproduces the bug (if applicable)\n2. Run the test to confirm it fails\n3. Write the minimal code to fix the issue\n4. Run tests to confirm the fix works and no regressions\n5. git add the changed files (specific files, not -A)\n6. git commit with a descriptive message\n\nIf tests fail, debug and fix. You have 3 attempts.\n\nOutput:\n{\"status\": \"success\", \"context_updates\": {\"implementation_summary\": \"YOUR SUMMARY: what files changed, what tests pass, what was fixed\"}}"
    ]

    // Comment draft — writes bridge.* output for GitHub comment
    comment_draft [
        label     = "Draft Comment",
        shape     = box,
        fillcolor = "#E8F0FE",
        prompt    = "Draft a GitHub issue comment summarizing the implementation.\n\nRead $implementation_summary for what was done.\n\nInclude:\n- Brief summary of what was fixed and how\n- Which files were changed\n- Test results\n- Suggest next step: the user can review the changes in the Resolve workspace\n\nOutput:\n{\"status\": \"success\", \"context_updates\": {\"bridge.comment\": \"YOUR COMMENT IN MARKDOWN\", \"bridge.summary\": \"ONE-LINE FIX SUMMARY\", \"bridge.labels\": [\"fix-implemented\"]}}"
    ]

    // Pipeline exit
    done [
        label     = "Done",
        shape     = Msquare,
        fillcolor = "#FFCDD2"
    ]

    // ═══════════════════════════════════════════════════════════════
    // EDGES
    // ═══════════════════════════════════════════════════════════════

    start -> planner
    planner -> implement_fix
    implement_fix -> comment_draft
    comment_draft -> done

}
